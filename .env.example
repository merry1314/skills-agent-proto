# Skills Agent 环境变量配置
# 复制此文件为 .env 并填入你的配置

# 通用模型配置（推荐）
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-opus-4-5-20251101
MODEL_API_KEY=sk_xxxx
MODEL_BASE_URL=https://api.jiekou.ai/anthropic

# Anthropic 兼容旧配置（可选，和上面的通用变量二选一即可）
# ANTHROPIC_AUTH_TOKEN=sk_xxxx
# ANTHROPIC_BASE_URL=https://api.jiekou.ai/anthropic
# CLAUDE_MODEL=claude-opus-4-5-20251101

# OpenAI / OpenAI-compatible 配置示例（如接口AI）
# MODEL_PROVIDER=openai
# MODEL_NAME=gpt-5.4
# MODEL_API_KEY=sk_xxxx
# MODEL_BASE_URL=https://api.jiekou.ai/openai
# OPENAI_REASONING_EFFORT=medium
#
# OpenAI thinking 默认会走 Responses API，并自动将
# https://api.jiekou.ai/openai 规范为 https://api.jiekou.ai/openai/v1
# 如需强制退回 chat/completions，可显式设置：
# OPENAI_USE_RESPONSES_API=false
#
# 或者使用 OpenAI 专属变量：
# OPENAI_API_KEY=sk_xxxx
# OPENAI_BASE_URL=https://api.jiekou.ai/openai
# OPENAI_MODEL=gpt-5.4

# 最大 tokens
MAX_TOKENS=16000

# 模型温度
MODEL_TEMPERATURE=1.0

# 权限模式 (default, acceptEdits, bypassPermissions)
PERMISSION_MODE=bypassPermissions
